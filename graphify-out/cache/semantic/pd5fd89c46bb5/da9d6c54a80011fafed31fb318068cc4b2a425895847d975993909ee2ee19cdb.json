{"nodes": [{"id": "plan_files_milestone_1_completion_report", "label": "Milestone 1 Completion Report", "file_type": "document", "source_file": "Plan Files/milestone_1_completion_report.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "plan_files_milestone_1_completion_report_agp9_kmp_plugin_migration", "label": "Migration to com.android.kotlin.multiplatform.library (AGP 9)", "file_type": "rationale", "source_file": "Plan Files/milestone_1_completion_report.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The master plan's original Phase 1 design (androidTarget() inside the KMP block combined with the classic com.android.library plugin) is incompatible with AGP 9.0+, bundled by this machine's Android Studio. Resolved by switching to the new AGP9-mandatory com.android.kotlin.multiplatform.library plugin and its kotlin { android { ... } } DSL; the plugin's own androidLibrary { ... } block was further found deprecated in favor of android { ... } in AGP 9.3.0."}, {"id": "plan_files_milestone_1_completion_report_gradle_daemon_heap_fix", "label": "Gradle Daemon Heap Size Fix (OutOfMemoryError)", "file_type": "rationale", "source_file": "Plan Files/milestone_1_completion_report.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The default Gradle daemon heap (512MB/384MB metaspace) was too small for lintVitalAnalyzeRelease's UAST analysis and crashed with an OutOfMemoryError. Fixed by adding gradle.properties with org.gradle.jvmargs=-Xmx2048m -XX:MaxMetaspaceSize=1024m."}, {"id": "plan_files_milestone_1_completion_report_android_gradle_plugin", "label": "Android Gradle Plugin 9.3.0", "file_type": "concept", "source_file": "Plan Files/milestone_1_completion_report.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": nu